@using MultiAgentSimWeb.Services
@using MultiAgentSimWeb.Models

@* Hidden SVG — pattern defs are document-scoped, usable by any SVG on this page *@
<svg width="0" height="0" style="position:absolute;overflow:hidden" aria-hidden="true">
    <defs>
        @* Street: near-black with subtle crosshair grid suggestion *@
        <pattern id="pattern-street" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
            <rect width="20" height="20" fill="#111118"/>
            <line x1="0" y1="10" x2="20" y2="10" stroke="#1e1e2a" stroke-width="1"/>
            <line x1="10" y1="0" x2="10" y2="20" stroke="#1e1e2a" stroke-width="1"/>
        </pattern>

        @* Park: deep green with irregular stipple dots — grass texture *@
        <pattern id="pattern-park" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
            <rect width="20" height="20" fill="#0c2a12"/>
            <circle cx="3"  cy="4"  r="1" fill="#1a4a20"/>
            <circle cx="9"  cy="7"  r="1" fill="#1a4a20"/>
            <circle cx="15" cy="3"  r="1" fill="#1a4a20"/>
            <circle cx="6"  cy="14" r="1" fill="#1a4a20"/>
            <circle cx="13" cy="11" r="1" fill="#1a4a20"/>
            <circle cx="17" cy="17" r="1" fill="#1a4a20"/>
        </pattern>

        @* Apartment: dark brown with horizontal brick lines and staggered verticals *@
        <pattern id="pattern-apartment" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
            <rect width="20" height="20" fill="#1e1612"/>
            <line x1="0" y1="5"  x2="20" y2="5"  stroke="#2a1e14" stroke-width="1"/>
            <line x1="0" y1="10" x2="20" y2="10" stroke="#2a1e14" stroke-width="1"/>
            <line x1="0" y1="15" x2="20" y2="15" stroke="#2a1e14" stroke-width="1"/>
            @* Staggered vertical dividers — offset per brick row *@
            <line x1="7"  y1="0"  x2="7"  y2="5"  stroke="#2a1e14" stroke-width="1"/>
            <line x1="13" y1="5"  x2="13" y2="10" stroke="#2a1e14" stroke-width="1"/>
            <line x1="7"  y1="10" x2="7"  y2="15" stroke="#2a1e14" stroke-width="1"/>
            <line x1="13" y1="15" x2="13" y2="20" stroke="#2a1e14" stroke-width="1"/>
        </pattern>

        @* Storefront: dark blue-gray with 3×2 grid of tiny window rects *@
        <pattern id="pattern-storefront" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
            <rect width="20" height="20" fill="#0d1a26"/>
            <rect x="2"  y="4"  width="3" height="2" fill="#1a3a50"/>
            <rect x="8"  y="4"  width="3" height="2" fill="#1a3a50"/>
            <rect x="14" y="4"  width="3" height="2" fill="#1a3a50"/>
            <rect x="2"  y="12" width="3" height="2" fill="#1a3a50"/>
            <rect x="8"  y="12" width="3" height="2" fill="#1a3a50"/>
            <rect x="14" y="12" width="3" height="2" fill="#1a3a50"/>
        </pattern>

        @* Industrial: dark amber with 45° diagonal hatch lines — metal grating *@
        <pattern id="pattern-industrial" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
            <rect width="20" height="20" fill="#1c160a"/>
            <line x1="0"  y1="15" x2="5"  y2="20" stroke="#261e0c" stroke-width="1"/>
            <line x1="0"  y1="10" x2="10" y2="20" stroke="#261e0c" stroke-width="1"/>
            <line x1="0"  y1="5"  x2="15" y2="20" stroke="#261e0c" stroke-width="1"/>
            <line x1="0"  y1="0"  x2="20" y2="20" stroke="#261e0c" stroke-width="1"/>
            <line x1="5"  y1="0"  x2="20" y2="15" stroke="#261e0c" stroke-width="1"/>
            <line x1="10" y1="0"  x2="20" y2="10" stroke="#261e0c" stroke-width="1"/>
            <line x1="15" y1="0"  x2="20" y2="5"  stroke="#261e0c" stroke-width="1"/>
        </pattern>
        @* Forest: dark green with irregular short vertical strokes — tree canopy *@
        <pattern id="pattern-forest" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
            <rect width="20" height="20" fill="#0a1f0c"/>
            <line x1="3"  y1="2"  x2="3"  y2="6"  stroke="#1a3d1e" stroke-width="1.5"/>
            <line x1="8"  y1="5"  x2="8"  y2="9"  stroke="#163519" stroke-width="1.5"/>
            <line x1="13" y1="1"  x2="13" y2="5"  stroke="#1a3d1e" stroke-width="1.5"/>
            <line x1="17" y1="7"  x2="17" y2="11" stroke="#163519" stroke-width="1.5"/>
            <line x1="5"  y1="13" x2="5"  y2="17" stroke="#1a3d1e" stroke-width="1.5"/>
            <line x1="11" y1="11" x2="11" y2="15" stroke="#163519" stroke-width="1.5"/>
            <line x1="16" y1="15" x2="16" y2="19" stroke="#1a3d1e" stroke-width="1.5"/>
        </pattern>

        @* River: deep blue with horizontal ripple lines *@
        <pattern id="pattern-river" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
            <rect width="20" height="20" fill="#091a2e"/>
            <path d="M0 5 Q5 3 10 5 Q15 7 20 5"  fill="none" stroke="#0d2d50" stroke-width="1"/>
            <path d="M0 10 Q5 8 10 10 Q15 12 20 10" fill="none" stroke="#0d3358" stroke-width="1"/>
            <path d="M0 15 Q5 13 10 15 Q15 17 20 15" fill="none" stroke="#0d2d50" stroke-width="1"/>
        </pattern>

        <symbol id="agent-person" viewBox="-5 -8 10 16" overflow="visible">
            @* head *@
            <circle cx="0" cy="-5.2" r="2.4" stroke="inherit" stroke-width="0.7" />
            @* torso / shoulders *@
            <path d="M-4 8 L-3.2 2.5 Q-1.5 0.5 0 0.5 Q1.5 0.5 3.2 2.5 L4 8 Z" stroke="inherit" stroke-width="0.7" />
        </symbol>
    </defs>
</svg>

<div class="map-panel">
    <div class="map-panel-header">
        <div class="map-panel-title">Map — 30×30</div>
        <div class="map-zoom-controls">
            <button class="zoom-btn" @onclick="ZoomOut" disabled="@(_cellSize <= _zoomLevels[0])">−</button>
            <button class="zoom-btn" @onclick="ZoomIn"  disabled="@(_cellSize >= _zoomLevels[_zoomLevels.Length - 1])">+</button>
        </div>
    </div>

    <div class="map-scroll-container">
        <svg width="@(_cellSize * World.MapWidth)"
             height="@(_cellSize * World.MapHeight)"
             xmlns="http://www.w3.org/2000/svg"
             @onmouseleave="() => _hoveredCell = null">

            @* Layer 1: Terrain *@
            @for (int row = 0; row < World.MapHeight; row++)
            {
                for (int col = 0; col < World.MapWidth; col++)
                {
                    var cx = col;
                    var cy = row;
                    var cell = World.GetCell(cx, cy);
                    <rect x="@(cx * _cellSize)"
                          y="@(cy * _cellSize)"
                          width="@_cellSize"
                          height="@_cellSize"
                          fill="@TerrainFill(cell.Terrain)"
                          stroke="#07070f"
                          stroke-width="0.4"
                          @onmouseover="e => { _hoveredCell = (cx, cy); _tooltipX = e.ClientX + 12; _tooltipY = e.ClientY - 8; }" />
                }
            }

            @* Layer 1b: Building name labels *@
            @foreach (var (label, cx, cy, floors) in _buildingLabels)
            {
                <g transform="translate(@cx.ToString("F1"), @cy.ToString("F1"))">
                    <text x="0" y="0"
                          font-size="5"
                          fill="#ffffff"
                          opacity="0.35"
                          text-anchor="middle"
                          dominant-baseline="middle"
                          font-family="'Segoe UI', system-ui, sans-serif"
                          style="user-select:none;pointer-events:none">@label</text>
                    <text x="8" y="-6"
                          font-size="4"
                          fill="#aaaacc"
                          opacity="@(floors > 1 ? "0.5" : "0")"
                          text-anchor="middle"
                          style="user-select:none;pointer-events:none">@(floors > 1 ? $"⌂{floors}" : "")</text>
                </g>
            }

            @* Layer 1c: Agent movement trails *@
            @foreach (var agentName in World.AgentNames)
            {
                var trail = World.GetAgentTrail(agentName);
                var hex = AgentColors.TryGetValue(agentName, out var h) ? h : "#888888";
                var opacities = new[] { 0.08, 0.13, 0.18, 0.25, 0.33, 0.42 };
                for (int ti = 0; ti < trail.Count; ti++)
                {
                    var (tx, ty) = trail[ti];
                    var op = opacities[Math.Min(ti, opacities.Length - 1)];
                    <circle cx="@(tx * _cellSize + _cellSize / 2)" cy="@(ty * _cellSize + _cellSize / 2)" r="5" fill="@hex" opacity="@op.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)" />
                }
            }

            @* Layer 2: Item markers *@
            @for (int row = 0; row < World.MapHeight; row++)
            {
                for (int col = 0; col < World.MapWidth; col++)
                {
                    if (World.HasItemsAt(col, row))
                    {
                        <rect x="@(col * _cellSize + _cellSize / 2 - 2)"
                              y="@(row * _cellSize + _cellSize / 2 - 2)"
                              width="4" height="4"
                              fill="#f59e0b" opacity="0.9"
                              rx="1" />
                    }
                }
            }

            @* Layer 2.5: Animal markers *@
            @foreach (var animal in World.GetAllAnimals())
            {
                double ax2 = animal.X * _cellSize + _cellSize * 0.75;
                double ay2 = animal.Y * _cellSize + _cellSize * 0.25;
                bool isLarge = animal.Size == MultiAgentSimWeb.Models.AnimalSize.Large;
                string aColor = isLarge ? "#ef4444" : "#86efac";
                int aFontSize = isLarge ? 9 : 7;
                string glyph = isLarge ? "✦" : "·";
                <g transform="translate(@ax2.ToString("F1"), @ay2.ToString("F1"))">
                    <text x="0" y="0" font-size="@aFontSize" fill="@aColor"
                          font-family="monospace" text-anchor="middle"
                          dominant-baseline="middle"
                          style="user-select:none">@glyph</text>
                </g>
            }

            @* Layer 3: Agent avatars — level-of-detail based on zoom *@
            @foreach (var (kvp, agentIdx) in AgentColors.Select((k, i) => (k, i)))
            {
                var (ax, ay) = World.GetAgentPosition(kvp.Key);
                if (ax >= 0)
                {
                    double cx = ax * _cellSize + _cellSize / 2.0;
                    double cy = ay * _cellSize + _cellSize / 2.0;
                    string color = kvp.Value;
                    <g transform="translate(@cx.ToString("F1"), @cy.ToString("F1"))"
                       style="cursor:pointer"
                       @onclick="() => OnAgentClicked.InvokeAsync(kvp.Key)">
                        <title>@kvp.Key (@ax, @ay) — click to inspect memory</title>
                        @if (_cellSize <= _zoomLevels[0])
                        {
                            @* Overview: simple dot *@
                            <circle cx="0" cy="0" r="4" fill="@color" stroke="#07070f" stroke-width="0.8" />
                        }
                        else if (_cellSize <= _zoomLevels[1])
                        {
                            @* Mid-zoom: polygon shape + initial *@
                            string points = ShapePoints[agentIdx % ShapePoints.Length];
                            string initial = kvp.Key.Length > 0 ? kvp.Key[0].ToString().ToUpper() : "?";
                            <polygon points="@points"
                                     fill="@color"
                                     stroke="#07070f"
                                     stroke-width="1.2"
                                     stroke-linejoin="round" />
                            <g>
                                <text x="0" y="2.8"
                                      text-anchor="middle"
                                      dominant-baseline="middle"
                                      font-family="'Segoe UI', system-ui, sans-serif"
                                      font-size="7"
                                      font-weight="800"
                                      fill="#0a0a18"
                                      style="user-select:none;pointer-events:none">@initial</text>
                            </g>
                        }
                        else
                        {
                            @* Detail zoom (28px+): person silhouette + short name *@
                            string shortName = kvp.Key.Length <= 4 ? kvp.Key : kvp.Key[..4];
                            <use href="#agent-person" x="-5" y="-8" width="10" height="16"
                                 fill="@color" stroke="#07070f" stroke-width="0.7" />
                            <g>
                                <text x="0" y="12"
                                      text-anchor="middle"
                                      font-family="'Segoe UI', system-ui, sans-serif"
                                      font-size="5.5"
                                      font-weight="700"
                                      fill="@color"
                                      style="user-select:none;pointer-events:none">@shortName</text>
                            </g>
                        }
                    </g>
                }
            }
        </svg>
    </div>

    @if (_hoveredCell.HasValue)
    {
        var (hx, hy) = _hoveredCell.Value;
        var hCell    = World.GetCell(hx, hy);
        var hItems   = World.GetItemsAt(hx, hy);
        var hAgents  = World.GetAgentsAtPosition(hx, hy);
        var hLogs    = World.GetCellLog(hx, hy);

        <div class="map-tooltip" style="left:@(_tooltipX.ToString("F0"))px;top:@(_tooltipY.ToString("F0"))px">
            <div class="map-tooltip-header">@(hCell.BuildingName ?? hCell.DisplayName)</div>
            <div class="map-tooltip-row">📍 @hCell.Terrain (@hx, @hy)</div>
            @if (hAgents.Any())
            {
                <div class="map-tooltip-row">👤 @string.Join(", ", hAgents)</div>
            }
            @if (hItems.Any())
            {
                <div class="map-tooltip-row">🎒 @string.Join(", ", hItems.Take(3).Select(i => i.DisplayName))</div>
            }
            @if (hLogs.Any())
            {
                @foreach (var entry in hLogs)
                {
                    <div class="map-tooltip-log">@entry</div>
                }
            }
        </div>
    }

    <div class="map-legends">
        @* Agent legend — uses matching mini-shape *@
        <div class="map-legend-group">
            @* Legend always uses mid-zoom polygon style — it's a fixed-size reference, not a live LOD mirror *@
            @foreach (var (kvp, agentIdx) in AgentColors.Select((k, i) => (k, i)))
            {
                var (ax, ay) = World.GetAgentPosition(kvp.Key);
                string points = ShapePoints[agentIdx % ShapePoints.Length];
                string initial = kvp.Key.Length > 0 ? kvp.Key[0].ToString().ToUpper() : "?";
                <span class="legend-item">
                    <svg width="14" height="14" viewBox="-7 -7 14 14">
                        <polygon points="@points"
                                 fill="@kvp.Value"
                                 stroke="#07070f"
                                 stroke-width="1"
                                 stroke-linejoin="round" />
                        <text x="0" y="1"
                              text-anchor="middle"
                              dominant-baseline="middle"
                              font-family="'Segoe UI', system-ui, sans-serif"
                              font-size="6"
                              font-weight="800"
                              fill="#0a0a18"
                              style="user-select:none">@initial</text>
                    </svg>
                    @kvp.Key @(ax >= 0 ? $"({ax},{ay})" : "†")
                </span>
            }
        </div>

        <div class="legend-divider"></div>

        @* Terrain legend *@
        <div class="map-legend-group">
            @foreach (var (label, fillId) in TerrainLegend)
            {
                <span class="legend-item">
                    <svg width="10" height="10" viewBox="0 0 10 10" style="vertical-align:middle">
                        <rect width="10" height="10" fill="@fillId"/>
                    </svg>
                    @label
                </span>
            }
            <span class="legend-item">
                <svg width="10" height="10" viewBox="0 0 10 10">
                    <rect x="3" y="3" width="4" height="4" fill="#f59e0b" rx="1"/>
                </svg>
                Items
            </span>
            <span class="legend-item">
                <svg width="10" height="10" viewBox="0 0 10 10">
                    <text x="5" y="8" text-anchor="middle" font-size="8" fill="#86efac" font-family="monospace">·</text>
                </svg>
                Small animal
            </span>
            <span class="legend-item">
                <svg width="10" height="10" viewBox="0 0 10 10">
                    <text x="5" y="8" text-anchor="middle" font-size="9" fill="#ef4444" font-family="monospace">✦</text>
                </svg>
                Feral dog
            </span>
        </div>
    </div>
</div>

@code {
    private int _cellSize = 20;
    private static readonly int[] _zoomLevels = { 12, 20, 28 };

    private (int x, int y)? _hoveredCell;
    private double _tooltipX, _tooltipY;

    [Parameter, EditorRequired] public WorldState World { get; set; } = default!;
    [Parameter, EditorRequired] public Dictionary<string, string> AgentColors { get; set; } = default!;
    [Parameter] public EventCallback<string> OnAgentClicked { get; set; }

    private WorldState? _lastWorld;
    private List<(string Label, double Cx, double Cy, int Floors)> _buildingLabels = [];

    // Five distinct shapes, all centered at (0,0), radius ~7.5px
    private static readonly string[] ShapePoints =
    [
        // 0: Hexagon
        "0,-7.5 6.5,-3.75 6.5,3.75 0,7.5 -6.5,3.75 -6.5,-3.75",
        // 1: Diamond (rotated square)
        "0,-7.5 7.5,0 0,7.5 -7.5,0",
        // 2: Upward triangle
        "0,-7.5 6.5,3.75 -6.5,3.75",
        // 3: Pentagon
        "0,-7.5 7.1,-2.3 4.4,6.1 -4.4,6.1 -7.1,-2.3",
        // 4: Five-pointed star
        "0,-7.5 2.1,-2.8 7.1,-2.3 3.3,1.1 4.4,6.1 0,3.5 -4.4,6.1 -3.3,1.1 -7.1,-2.3 -2.1,-2.8",
    ];

    private static readonly (string label, string fillId)[] TerrainLegend =
    [
        ("Street",     "url(#pattern-street)"),
        ("Apartment",  "url(#pattern-apartment)"),
        ("Storefront", "url(#pattern-storefront)"),
        ("Park",       "url(#pattern-park)"),
        ("Industrial", "url(#pattern-industrial)"),
        ("Forest",     "url(#pattern-forest)"),
        ("River",      "url(#pattern-river)"),
    ];

    protected override void OnParametersSet()
    {
        if (World != _lastWorld)
        {
            _lastWorld = World;
            _buildingLabels = ComputeBuildingLabels();
        }
    }

    private List<(string Label, double Cx, double Cy, int Floors)> ComputeBuildingLabels()
    {
        var groups = new Dictionary<string, (int minX, int maxX, int minY, int maxY, int floors)>();
        for (int row = 0; row < World.MapHeight; row++)
        {
            for (int col = 0; col < World.MapWidth; col++)
            {
                var cell = World.GetCell(col, row);
                var name = cell.BuildingName;
                if (name is null) continue;
                if (groups.TryGetValue(name, out var b))
                    groups[name] = (Math.Min(b.minX, col), Math.Max(b.maxX, col),
                                    Math.Min(b.minY, row), Math.Max(b.maxY, row), b.floors);
                else
                    groups[name] = (col, col, row, row, cell.Floors);
            }
        }
        var result = new List<(string Label, double Cx, double Cy, int Floors)>(groups.Count);
        foreach (var (name, b) in groups)
        {
            double cx = ((b.minX + b.maxX) / 2.0 + 0.5) * _cellSize;
            double cy = ((b.minY + b.maxY) / 2.0 + 0.5) * _cellSize;
            result.Add((AbbreviateName(name), cx, cy, b.floors));
        }
        return result;
    }

    private static string AbbreviateName(string name)
    {
        var words = name.Split(' ');
        // Skip leading "The" and return the next word
        string first = words[0].Equals("The", StringComparison.OrdinalIgnoreCase) && words.Length > 1
            ? words[1] : words[0];
        // Two-word abbrev for "Elm Street…"
        if (first.Equals("Elm", StringComparison.OrdinalIgnoreCase) && words.Length > 1)
            return "Elm St.";
        return first.Length > 9 ? first[..8] : first;
    }

    private void ZoomOut()
    {
        int idx = Array.IndexOf(_zoomLevels, _cellSize);
        if (idx > 0) { _cellSize = _zoomLevels[idx - 1]; _buildingLabels = ComputeBuildingLabels(); StateHasChanged(); }
    }

    private void ZoomIn()
    {
        int idx = Array.IndexOf(_zoomLevels, _cellSize);
        if (idx < _zoomLevels.Length - 1) { _cellSize = _zoomLevels[idx + 1]; _buildingLabels = ComputeBuildingLabels(); StateHasChanged(); }
    }

    private static string TerrainFill(TerrainType terrain) => terrain switch
    {
        TerrainType.Street     => "url(#pattern-street)",
        TerrainType.Apartment  => "url(#pattern-apartment)",
        TerrainType.Storefront => "url(#pattern-storefront)",
        TerrainType.Park       => "url(#pattern-park)",
        TerrainType.Industrial => "url(#pattern-industrial)",
        TerrainType.Forest     => "url(#pattern-forest)",
        TerrainType.River      => "url(#pattern-river)",
        _                      => "#0f0f1e"
    };
}
