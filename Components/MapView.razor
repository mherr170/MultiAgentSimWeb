@using MultiAgentSimWeb.Services
@using MultiAgentSimWeb.Models
@inject IJSRuntime JS

@* Hidden SVG — pattern defs are document-scoped, usable by any SVG on this page *@
<svg width="0" height="0" style="position:absolute;overflow:hidden" aria-hidden="true">
    <defs>
        @* Street: dark asphalt with faint pavement block joints and grit specks *@
        <pattern id="pattern-street" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
            <rect width="40" height="40" fill="#14141e"/>
            @* Pavement slab joints *@
            <line x1="0"  y1="20" x2="40" y2="20" stroke="#1c1c2c" stroke-width="1.2"/>
            <line x1="20" y1="0"  x2="20" y2="40" stroke="#1c1c2c" stroke-width="1.2"/>
            @* Sub-joint lines — softer *@
            <line x1="0"  y1="10" x2="40" y2="10" stroke="#191927" stroke-width="0.5"/>
            <line x1="0"  y1="30" x2="40" y2="30" stroke="#191927" stroke-width="0.5"/>
            <line x1="10" y1="0"  x2="10" y2="40" stroke="#191927" stroke-width="0.5"/>
            <line x1="30" y1="0"  x2="30" y2="40" stroke="#191927" stroke-width="0.5"/>
            @* Grit specks *@
            <circle cx="5"  cy="5"  r="0.6" fill="#1e1e2e"/>
            <circle cx="15" cy="33" r="0.6" fill="#1e1e2e"/>
            <circle cx="27" cy="8"  r="0.6" fill="#1e1e2e"/>
            <circle cx="35" cy="18" r="0.6" fill="#1e1e2e"/>
            <circle cx="9"  cy="26" r="0.6" fill="#1e1e2e"/>
        </pattern>

        @* Park: rich grass with varied stipple and fine blade strokes *@
        <pattern id="pattern-park" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
            <rect width="20" height="20" fill="#0d2e14"/>
            @* Base grass blades — short vertical strokes *@
            <line x1="2"  y1="7"  x2="1"  y2="4"  stroke="#1d5225" stroke-width="1"/>
            <line x1="5"  y1="15" x2="4"  y2="12" stroke="#175020" stroke-width="1"/>
            <line x1="9"  y1="5"  x2="8"  y2="2"  stroke="#1d5225" stroke-width="1"/>
            <line x1="12" y1="13" x2="11" y2="10" stroke="#175020" stroke-width="1"/>
            <line x1="16" y1="4"  x2="15" y2="1"  stroke="#1a4e22" stroke-width="1"/>
            <line x1="18" y1="17" x2="17" y2="14" stroke="#1d5225" stroke-width="1"/>
            <line x1="7"  y1="18" x2="6"  y2="15" stroke="#175020" stroke-width="1"/>
            <line x1="14" y1="8"  x2="13" y2="5"  stroke="#1a4e22" stroke-width="1"/>
            @* Stipple: varied sizes for depth *@
            <circle cx="3"  cy="10" r="1.2" fill="#1a4a20" opacity="0.7"/>
            <circle cx="10" cy="17" r="0.8" fill="#22602a" opacity="0.6"/>
            <circle cx="17" cy="11" r="1.0" fill="#1a4a20" opacity="0.7"/>
            <circle cx="6"  cy="3"  r="0.7" fill="#22602a" opacity="0.5"/>
            <circle cx="14" cy="19" r="0.9" fill="#1a4a20" opacity="0.6"/>
        </pattern>

        @* Apartment: brick with staggered rows, mortar lines, and dim window hints *@
        <pattern id="pattern-apartment" x="0" y="0" width="24" height="20" patternUnits="userSpaceOnUse">
            <rect width="24" height="20" fill="#201510"/>
            @* Mortar horizontal lines *@
            <line x1="0" y1="5"  x2="24" y2="5"  stroke="#2e1c12" stroke-width="0.8"/>
            <line x1="0" y1="10" x2="24" y2="10" stroke="#2e1c12" stroke-width="0.8"/>
            <line x1="0" y1="15" x2="24" y2="15" stroke="#2e1c12" stroke-width="0.8"/>
            @* Row 0 (0-5): brick dividers every 8px *@
            <line x1="8"  y1="0"  x2="8"  y2="5"  stroke="#2e1c12" stroke-width="0.8"/>
            <line x1="16" y1="0"  x2="16" y2="5"  stroke="#2e1c12" stroke-width="0.8"/>
            @* Row 1 (5-10): staggered — offset 4 *@
            <line x1="4"  y1="5"  x2="4"  y2="10" stroke="#2e1c12" stroke-width="0.8"/>
            <line x1="12" y1="5"  x2="12" y2="10" stroke="#2e1c12" stroke-width="0.8"/>
            <line x1="20" y1="5"  x2="20" y2="10" stroke="#2e1c12" stroke-width="0.8"/>
            @* Row 2 (10-15): same as row 0 *@
            <line x1="8"  y1="10" x2="8"  y2="15" stroke="#2e1c12" stroke-width="0.8"/>
            <line x1="16" y1="10" x2="16" y2="15" stroke="#2e1c12" stroke-width="0.8"/>
            @* Row 3 (15-20): staggered *@
            <line x1="4"  y1="15" x2="4"  y2="20" stroke="#2e1c12" stroke-width="0.8"/>
            <line x1="12" y1="15" x2="12" y2="20" stroke="#2e1c12" stroke-width="0.8"/>
            <line x1="20" y1="15" x2="20" y2="20" stroke="#2e1c12" stroke-width="0.8"/>
            @* Brick face variation — slight highlight on some bricks *@
            <rect x="0"  y="0"  width="7"  height="4" fill="#251811" rx="0.5"/>
            <rect x="9"  y="5"  width="7"  height="4" fill="#251811" rx="0.5"/>
            <rect x="0"  y="10" width="7"  height="4" fill="#251811" rx="0.5"/>
            @* Dim window hints *@
            <rect x="3"  y="1"  width="2" height="1.5" fill="#1e2e3a" opacity="0.8"/>
            <rect x="11" y="6"  width="2" height="1.5" fill="#1e2e3a" opacity="0.8"/>
            <rect x="3"  y="11" width="2" height="1.5" fill="#1e2e3a" opacity="0.8"/>
        </pattern>

        @* Storefront: facade with window grid, awning band, and centered door *@
        <pattern id="pattern-storefront" x="0" y="0" width="20" height="24" patternUnits="userSpaceOnUse">
            <rect width="20" height="24" fill="#0e1c2e"/>
            @* Awning band at top *@
            <rect x="0" y="0" width="20" height="5" fill="#152740"/>
            <line x1="0" y1="5" x2="20" y2="5" stroke="#1e3a5a" stroke-width="0.8"/>
            @* Awning stripes *@
            <line x1="4"  y1="0" x2="4"  y2="5" stroke="#1a3050" stroke-width="0.6"/>
            <line x1="8"  y1="0" x2="8"  y2="5" stroke="#1a3050" stroke-width="0.6"/>
            <line x1="12" y1="0" x2="12" y2="5" stroke="#1a3050" stroke-width="0.6"/>
            <line x1="16" y1="0" x2="16" y2="5" stroke="#1a3050" stroke-width="0.6"/>
            @* Upper window row *@
            <rect x="1"  y="7"  width="5" height="4" fill="#1c3e58" rx="0.5"/>
            <rect x="8"  y="7"  width="5" height="4" fill="#1c4260" rx="0.5"/>
            <rect x="14" y="7"  width="5" height="4" fill="#1c3e58" rx="0.5"/>
            @* Window glint *@
            <line x1="2"  y1="8"  x2="4"  y2="10" stroke="#3a6a8a" stroke-width="0.4" opacity="0.5"/>
            <line x1="9"  y1="8"  x2="11" y2="10" stroke="#3a6a8a" stroke-width="0.4" opacity="0.5"/>
            @* Facade wall *@
            <line x1="0" y1="13" x2="20" y2="13" stroke="#14283d" stroke-width="0.7"/>
            @* Lower window row *@
            <rect x="1"  y="15" width="5" height="4" fill="#1c3e58" rx="0.5"/>
            <rect x="14" y="15" width="5" height="4" fill="#1c3e58" rx="0.5"/>
            @* Center door *@
            <rect x="8"  y="16" width="4" height="8" fill="#152234" rx="0.5"/>
            <circle cx="11" cy="20" r="0.5" fill="#3a6a8a"/>
        </pattern>

        @* Industrial: corrugated metal panels with rivet marks and cross-hatch *@
        <pattern id="pattern-industrial" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
            <rect width="20" height="20" fill="#1c1608"/>
            @* Panel lines — horizontal corrugation *@
            <line x1="0" y1="4"  x2="20" y2="4"  stroke="#251f0c" stroke-width="1.2"/>
            <line x1="0" y1="8"  x2="20" y2="8"  stroke="#221c0a" stroke-width="0.7"/>
            <line x1="0" y1="12" x2="20" y2="12" stroke="#251f0c" stroke-width="1.2"/>
            <line x1="0" y1="16" x2="20" y2="16" stroke="#221c0a" stroke-width="0.7"/>
            @* Vertical panel seams *@
            <line x1="10" y1="0" x2="10" y2="20" stroke="#221c0a" stroke-width="0.8"/>
            @* Diagonal hatch on alt panels — bottom-right to top-right direction *@
            <line x1="0"  y1="8"  x2="4"  y2="4"  stroke="#221c0a" stroke-width="0.5"/>
            <line x1="4"  y1="8"  x2="8"  y2="4"  stroke="#221c0a" stroke-width="0.5"/>
            <line x1="10" y1="12" x2="14" y2="8"  stroke="#221c0a" stroke-width="0.5"/>
            <line x1="14" y1="12" x2="18" y2="8"  stroke="#221c0a" stroke-width="0.5"/>
            <line x1="10" y1="20" x2="14" y2="16" stroke="#221c0a" stroke-width="0.5"/>
            <line x1="14" y1="20" x2="18" y2="16" stroke="#221c0a" stroke-width="0.5"/>
            @* Rivet dots at panel corners *@
            <circle cx="0"  cy="4"  r="0.8" fill="#2e2610"/>
            <circle cx="10" cy="4"  r="0.8" fill="#2e2610"/>
            <circle cx="20" cy="4"  r="0.8" fill="#2e2610"/>
            <circle cx="0"  cy="12" r="0.8" fill="#2e2610"/>
            <circle cx="10" cy="12" r="0.8" fill="#2e2610"/>
            <circle cx="20" cy="12" r="0.8" fill="#2e2610"/>
        </pattern>

        @* Forest: overlapping canopy blobs with trunk marks and undergrowth *@
        <pattern id="pattern-forest" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
            <rect width="20" height="20" fill="#09200b"/>
            @* Trunk marks *@
            <rect x="2"  y="10" width="1.5" height="5" fill="#1a2e10" rx="0.5"/>
            <rect x="9"  y="13" width="1.5" height="5" fill="#1a2e10" rx="0.5"/>
            <rect x="15" y="8"  width="1.5" height="5" fill="#162a0e" rx="0.5"/>
            @* Canopy blobs — irregular circles layered *@
            <circle cx="3"  cy="9"  r="4.5" fill="#13361a" opacity="0.85"/>
            <circle cx="10" cy="12" r="4"   fill="#0f3015" opacity="0.8"/>
            <circle cx="16" cy="7"  r="4.5" fill="#13361a" opacity="0.85"/>
            <circle cx="5"  cy="16" r="3"   fill="#163d1c" opacity="0.7"/>
            <circle cx="14" cy="17" r="3.5" fill="#0f3015" opacity="0.7"/>
            @* Highlight tops *@
            <circle cx="3"  cy="7"  r="1.5" fill="#1d4e25" opacity="0.5"/>
            <circle cx="16" cy="5"  r="1.5" fill="#1d4e25" opacity="0.5"/>
        </pattern>

        @* River: deep water with layered wave ripples and light glints *@
        <pattern id="pattern-river" x="0" y="0" width="40" height="20" patternUnits="userSpaceOnUse">
            <rect width="40" height="20" fill="#091e35"/>
            @* Deep current — subtle dark band *@
            <rect x="0" y="8" width="40" height="5" fill="#071629" opacity="0.5"/>
            @* Ripple waves — three layers of varying depth *@
            <path d="M0 4 Q5 2 10 4 Q15 6 20 4 Q25 2 30 4 Q35 6 40 4"    fill="none" stroke="#0e2e50" stroke-width="1.2"/>
            <path d="M0 9 Q7 7 14 9 Q21 11 28 9 Q35 7 40 9"              fill="none" stroke="#0f3560" stroke-width="0.9"/>
            <path d="M0 14 Q5 12 10 14 Q15 16 20 14 Q25 12 30 14 Q35 16 40 14" fill="none" stroke="#0e2e50" stroke-width="1.2"/>
            <path d="M0 18 Q7 16 14 18 Q21 20 28 18 Q35 16 40 18"        fill="none" stroke="#0d2848" stroke-width="0.7"/>
            @* Light glint specks on water surface *@
            <circle cx="6"  cy="4"  r="0.8" fill="#1a4e7a" opacity="0.6"/>
            <circle cx="22" cy="14" r="0.8" fill="#1a4e7a" opacity="0.6"/>
            <circle cx="34" cy="9"  r="0.6" fill="#1e5a88" opacity="0.5"/>
            <circle cx="12" cy="18" r="0.5" fill="#1a4e7a" opacity="0.4"/>
        </pattern>

        <symbol id="agent-person" viewBox="-5 -8 10 16" overflow="visible">
            @* head *@
            <circle cx="0" cy="-5.2" r="2.4" stroke="inherit" stroke-width="0.7" />
            @* torso / shoulders *@
            <path d="M-4 8 L-3.2 2.5 Q-1.5 0.5 0 0.5 Q1.5 0.5 3.2 2.5 L4 8 Z" stroke="inherit" stroke-width="0.7" />
        </symbol>
    </defs>
</svg>

<div class="map-panel">
    @if (!CompactHeader)
    {
        <div class="map-panel-header">
            <div class="map-panel-title">Map — 40×40</div>
            <div class="map-zoom-controls">
                <button class="zoom-btn" @onclick="ZoomOut" disabled="@(_cellSize <= _zoomLevels[0])">−</button>
                <button class="zoom-btn" @onclick="ZoomIn"  disabled="@(_cellSize >= _zoomLevels[_zoomLevels.Length - 1])">+</button>
            </div>
        </div>
    }

    <div class="map-viewport">
    <div class="map-scroll-container" @ref="_scrollContainer">
        <svg width="@(_cellSize * World.MapWidth)"
             height="@(_cellSize * World.MapHeight)"
             xmlns="http://www.w3.org/2000/svg"
             @onmouseleave="() => _hoveredCell = null">

            @* Layer 1: Terrain — no stroke so terrain tiles flow continuously *@
            @for (int row = 0; row < World.MapHeight; row++)
            {
                for (int col = 0; col < World.MapWidth; col++)
                {
                    var cx = col;
                    var cy = row;
                    var cell = World.GetCell(cx, cy);
                    <rect x="@(cx * _cellSize)"
                          y="@(cy * _cellSize)"
                          width="@(_cellSize + 1)"
                          height="@(_cellSize + 1)"
                          fill="@TerrainFill(cell.Terrain)"
                          stroke="none"
                          @onmouseover="e => { _hoveredCell = (cx, cy); _tooltipX = e.ClientX + 12; _tooltipY = e.ClientY - 8; }" />
                }
            }

            @* Layer 1.5: Faint cell grid — only visible at 28px+ to aid navigation *@
            @if (_cellSize >= 28)
            {
                @for (int row = 0; row < World.MapHeight; row++)
                {
                    for (int col = 0; col < World.MapWidth; col++)
                    {
                        <rect x="@(col * _cellSize)"
                              y="@(row * _cellSize)"
                              width="@_cellSize"
                              height="@_cellSize"
                              fill="none"
                              stroke="#1a1a2a"
                              stroke-width="0.3"
                              style="pointer-events:none" />
                    }
                }
            }

            @* Layer 1b: Building fills — semi-transparent color wash over terrain *@
            @foreach (var b in _buildings)
            {
                <rect x="@b.Ox.ToString("F1")"
                      y="@b.Oy.ToString("F1")"
                      width="@b.Ow.ToString("F1")"
                      height="@b.Oh.ToString("F1")"
                      fill="@BuildingFillColor(b.Terrain)"
                      stroke="none"
                      opacity="0.18"
                      style="pointer-events:none" />
            }

            @* Layer 1c: Building outlines — one rect per named block *@
            @foreach (var b in _buildings)
            {
                <rect x="@b.Ox.ToString("F1")"
                      y="@b.Oy.ToString("F1")"
                      width="@b.Ow.ToString("F1")"
                      height="@b.Oh.ToString("F1")"
                      fill="none"
                      stroke="@BuildingOutlineColor(b.Terrain)"
                      stroke-width="1.5"
                      style="pointer-events:none" />
            }

            @* Layer 1c: Building name labels *@
            @foreach (var b in _buildings)
            {
                <g transform="translate(@b.Cx.ToString("F1"), @b.Cy.ToString("F1"))">
                    <text x="0" y="0"
                          font-size="5"
                          fill="#ffffff"
                          opacity="0.35"
                          text-anchor="middle"
                          dominant-baseline="middle"
                          font-family="'Segoe UI', system-ui, sans-serif"
                          style="user-select:none;pointer-events:none">@b.Label</text>
                    <text x="8" y="-6"
                          font-size="4"
                          fill="#aaaacc"
                          opacity="@(b.Floors > 1 ? "0.5" : "0")"
                          text-anchor="middle"
                          style="user-select:none;pointer-events:none">@(b.Floors > 1 ? $"⌂{b.Floors}" : "")</text>
                </g>
            }

            @* Layer 1d: Agent movement trails — line segments fading toward oldest *@
            @foreach (var agentName in World.AgentNames)
            {
                var trail = World.GetAgentTrail(agentName);
                var hex = AgentColors.TryGetValue(agentName, out var h) ? h : "#888888";
                @* Draw segments from oldest→newest; opacity increases toward newest *@
                for (int ti = 0; ti < trail.Count - 1; ti++)
                {
                    var (tx1, ty1) = trail[ti];
                    var (tx2, ty2) = trail[ti + 1];
                    double progress = trail.Count <= 1 ? 1.0 : (double)ti / (trail.Count - 1);
                    double op = 0.06 + progress * 0.36;
                    double strokeW = 1.2 + progress * 2.0;
                    double cx1 = tx1 * _cellSize + _cellSize / 2.0;
                    double cy1 = ty1 * _cellSize + _cellSize / 2.0;
                    double cx2 = tx2 * _cellSize + _cellSize / 2.0;
                    double cy2 = ty2 * _cellSize + _cellSize / 2.0;
                    <line x1="@cx1.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                          y1="@cy1.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                          x2="@cx2.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                          y2="@cy2.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                          stroke="@hex"
                          stroke-width="@strokeW.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                          stroke-linecap="round"
                          opacity="@op.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                          style="pointer-events:none" />
                }
            }

            @* Layer 2: Item markers with count *@
            @for (int row = 0; row < World.MapHeight; row++)
            {
                for (int col = 0; col < World.MapWidth; col++)
                {
                    if (World.HasItemsAt(col, row))
                    {
                        var itemCount = World.GetItemsAt(col, row).Count;
                        double imx = col * _cellSize + _cellSize * 0.5;
                        double imy = row * _cellSize + _cellSize * 0.5;
                        <circle cx="@imx.ToString("F1")" cy="@imy.ToString("F1")"
                                r="2.5" fill="#f59e0b" opacity="0.9" />
                        @if (itemCount > 1 && _cellSize >= 12)
                        {
                            string itx = (imx + 3.5).ToString("F1", System.Globalization.CultureInfo.InvariantCulture);
                            string ity = (imy + 1.5).ToString("F1", System.Globalization.CultureInfo.InvariantCulture);
                            <g><text x="@itx" y="@ity"
                                     font-size="4" fill="#f59e0b" opacity="0.9"
                                     font-family="'Segoe UI', system-ui, sans-serif"
                                     style="user-select:none;pointer-events:none">@itemCount</text></g>
                        }
                    }
                }
            }

            @* Layer 2.5: Animal markers *@
            @foreach (var animal in World.GetAllAnimals())
            {
                double ax2 = animal.X * _cellSize + _cellSize * 0.75;
                double ay2 = animal.Y * _cellSize + _cellSize * 0.25;
                bool isLarge = animal.Size == MultiAgentSimWeb.Models.AnimalSize.Large;
                string aColor = isLarge ? "#ef4444" : "#86efac";
                string glyph = AnimalGlyph(animal.Type);
                int aFontSize = isLarge ? (_cellSize >= 20 ? 11 : 9) : (_cellSize >= 20 ? 9 : 7);
                <g transform="translate(@ax2.ToString("F1"), @ay2.ToString("F1"))">
                    <text x="0" y="0" font-size="@aFontSize" fill="@aColor"
                          font-family="monospace" text-anchor="middle"
                          dominant-baseline="middle"
                          style="user-select:none">@glyph</text>
                </g>
            }

            @* Layer 3: Agent avatars — level-of-detail based on zoom *@
            @foreach (var (kvp, agentIdx) in AgentColors.Select((k, i) => (k, i)))
            {
                var (ax, ay) = World.GetAgentPosition(kvp.Key);
                if (ax >= 0)
                {
                    double cx    = ax * _cellSize + _cellSize / 2.0;
                    double cy    = ay * _cellSize + _cellSize / 2.0;
                    string color = kvp.Value;
                    bool isActive = kvp.Key == CurrentAgent;
                    float hunger  = World.GetHunger(kvp.Key);
                    float thirst  = World.GetThirst(kvp.Key);
                    string ringColor = HealthRingColor(hunger, thirst);
                    double ringR = _cellSize * 0.44;
                    int floor = World.GetAgentFloor(kvp.Key);

                    string glowStyle = isActive
                        ? $"cursor:pointer;filter:drop-shadow(0 0 {Math.Max(3, _cellSize * 0.18):F0}px {color}) drop-shadow(0 0 {Math.Max(6, _cellSize * 0.35):F0}px {color}40)"
                        : $"cursor:pointer;filter:drop-shadow(0 0 2px {color}60)";
                    <g transform="translate(@cx.ToString("F1"), @cy.ToString("F1"))"
                       style="@glowStyle"
                       @onclick="() => OnAgentClicked.InvokeAsync(kvp.Key)">
                        <title>@kvp.Key (@ax,@ay) F@floor — H:@hunger.ToString("F0") T:@thirst.ToString("F0") — click to inspect</title>

                        @* Active-agent pulse ring (behind everything) *@
                        @if (isActive)
                        {
                            <circle cx="0" cy="0" r="@ringR.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                                    fill="none" stroke="@color" stroke-width="1.5"
                                    class="agent-active-ring" />
                        }

                        @* Health ring *@
                        @if (_cellSize >= 12)
                        {
                            <circle cx="0" cy="0" r="@ringR.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                                    fill="none" stroke="@ringColor" stroke-width="1.2" opacity="0.7"
                                    style="pointer-events:none" />
                        }

                        @* Avatar shape — LOD *@
                        @if (_cellSize <= 12)
                        {
                            @* Overview / small: dot *@
                            <circle cx="0" cy="0" r="@(_cellSize * 0.30)" fill="@color" stroke="#07070f" stroke-width="0.8" />
                        }
                        else if (_cellSize <= 20)
                        {
                            @* Mid-zoom: polygon + initial *@
                            string pts     = ShapePoints[agentIdx % ShapePoints.Length];
                            string initial = kvp.Key.Length > 0 ? kvp.Key[0].ToString().ToUpper() : "?";
                            <polygon points="@pts" fill="@color" stroke="#07070f" stroke-width="1.2" stroke-linejoin="round" />
                            <g><text x="0" y="2.8" text-anchor="middle" dominant-baseline="middle"
                                     font-family="'Segoe UI', system-ui, sans-serif"
                                     font-size="7" font-weight="800" fill="#0a0a18"
                                     style="user-select:none;pointer-events:none">@initial</text></g>
                        }
                        else
                        {
                            @* Detail (28px+): silhouette + name *@
                            string shortName = kvp.Key.Length <= 4 ? kvp.Key : kvp.Key[..4];
                            <use href="#agent-person" x="-5" y="-8" width="10" height="16"
                                 fill="@color" stroke="#07070f" stroke-width="0.7" />
                            <g><text x="0" y="12" text-anchor="middle"
                                     font-family="'Segoe UI', system-ui, sans-serif"
                                     font-size="5.5" font-weight="700" fill="@color"
                                     style="user-select:none;pointer-events:none">@shortName</text></g>
                        }

                        @* Floor badge — shown when above floor 1 *@
                        @if (floor > 1 && _cellSize >= 12)
                        {
                            double badgeX = _cellSize * 0.32;
                            double badgeY = -_cellSize * 0.32;
                            double fSize  = Math.Max(3.5, _cellSize * 0.18);
                            <g><text x="@badgeX.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                                     y="@badgeY.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                                     font-size="@fSize.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                                     fill="@color" font-weight="700"
                                     text-anchor="middle" dominant-baseline="middle"
                                     font-family="'Segoe UI', system-ui, sans-serif"
                                     style="user-select:none;pointer-events:none">F@floor</text></g>
                        }
                    </g>
                }
            }
            @* Layer 5: Time-of-day lighting overlay *@
            @{
                var (todColor, todOpacity) = World.CurrentPhase switch
                {
                    DayPhase.Night => ("#0a0818", "0.58"),
                    DayPhase.Dawn  => ("#261408", "0.22"),
                    DayPhase.Dusk  => ("#2a0e06", "0.28"),
                    _              => ("#000000", "0.00"),
                };
            }
            @if (todOpacity != "0.00")
            {
                <rect x="0" y="0"
                      width="@(_cellSize * World.MapWidth)"
                      height="@(_cellSize * World.MapHeight)"
                      fill="@todColor"
                      opacity="@todOpacity"
                      style="pointer-events:none" />
            }
        </svg>
    </div>

    </div>@* end map-viewport *@

    @if (_hoveredCell.HasValue)
    {
        var (hx, hy) = _hoveredCell.Value;
        var hCell    = World.GetCell(hx, hy);
        var hItems   = World.GetItemsAt(hx, hy);
        var hAgents  = World.GetAgentsAtPosition(hx, hy);
        var hLogs    = World.GetCellLog(hx, hy);

        <div class="map-tooltip" style="left:@(_tooltipX.ToString("F0"))px;top:@(_tooltipY.ToString("F0"))px">
            <div class="map-tooltip-header">@(hCell.BuildingName ?? hCell.DisplayName)</div>
            <div class="map-tooltip-row">📍 @hCell.Terrain (@hx, @hy)</div>
            @if (hAgents.Any())
            {
                <div class="map-tooltip-row">👤 @string.Join(", ", hAgents)</div>
            }
            @if (hItems.Any())
            {
                <div class="map-tooltip-row">🎒 @string.Join(", ", hItems.Take(3).Select(i => i.DisplayName))</div>
            }
            @if (hLogs.Any())
            {
                @foreach (var entry in hLogs)
                {
                    <div class="map-tooltip-log">@entry</div>
                }
            }
        </div>
    }

    <div class="map-legends">
        @* Agent legend — uses matching mini-shape *@
        <div class="map-legend-group">
            @* Legend always uses mid-zoom polygon style — it's a fixed-size reference, not a live LOD mirror *@
            @foreach (var (kvp, agentIdx) in AgentColors.Select((k, i) => (k, i)))
            {
                var (ax, ay) = World.GetAgentPosition(kvp.Key);
                string points = ShapePoints[agentIdx % ShapePoints.Length];
                string initial = kvp.Key.Length > 0 ? kvp.Key[0].ToString().ToUpper() : "?";
                <span class="legend-item">
                    <svg width="14" height="14" viewBox="-7 -7 14 14">
                        <polygon points="@points"
                                 fill="@kvp.Value"
                                 stroke="#07070f"
                                 stroke-width="1"
                                 stroke-linejoin="round" />
                        <text x="0" y="1"
                              text-anchor="middle"
                              dominant-baseline="middle"
                              font-family="'Segoe UI', system-ui, sans-serif"
                              font-size="6"
                              font-weight="800"
                              fill="#0a0a18"
                              style="user-select:none">@initial</text>
                    </svg>
                    @kvp.Key @(ax >= 0 ? $"({ax},{ay})" : "†")
                </span>
            }
        </div>

        <div class="legend-divider"></div>

        @* Terrain legend *@
        <div class="map-legend-group">
            @foreach (var (label, fillId) in TerrainLegend)
            {
                <span class="legend-item">
                    <svg width="10" height="10" viewBox="0 0 10 10" style="vertical-align:middle">
                        <rect width="10" height="10" fill="@fillId"/>
                    </svg>
                    @label
                </span>
            }
            <span class="legend-item">
                <svg width="10" height="10" viewBox="0 0 10 10">
                    <rect x="3" y="3" width="4" height="4" fill="#f59e0b" rx="1"/>
                </svg>
                Items
            </span>
            <span class="legend-item" style="color:#86efac;font-size:0.7rem">🐀🐦🐱🐿🦊 small</span>
            <span class="legend-item" style="color:#ef4444;font-size:0.7rem">🐕🦮🐶🐺🦌 large</span>
        </div>
    </div>
</div>

@code {
    private int _cellSize = 12;
    private static readonly int[] _zoomLevels = { 8, 12, 20, 28, 40 };

    private (int x, int y)? _hoveredCell;
    private double _tooltipX, _tooltipY;

    [Parameter, EditorRequired] public WorldState World { get; set; } = default!;
    [Parameter, EditorRequired] public Dictionary<string, string> AgentColors { get; set; } = default!;
    [Parameter] public string? CurrentAgent  { get; set; }
    [Parameter] public EventCallback<string> OnAgentClicked { get; set; }
    [Parameter] public bool CompactHeader    { get; set; }
    [Parameter] public string? FollowedAgent { get; set; }

    private record BuildingData(
        string Label, double Cx, double Cy, int Floors,
        double Ox, double Oy, double Ow, double Oh,
        TerrainType Terrain);

    private WorldState? _lastWorld;
    private List<BuildingData> _buildings = [];
    private ElementReference _scrollContainer;
    private string? _prevCurrentAgent;
    private string? _prevFollowedAgent;
    private bool _pendingCenter;

    // Five distinct shapes, all centered at (0,0), radius ~7.5px
    private static readonly string[] ShapePoints =
    [
        // 0: Hexagon
        "0,-7.5 6.5,-3.75 6.5,3.75 0,7.5 -6.5,3.75 -6.5,-3.75",
        // 1: Diamond (rotated square)
        "0,-7.5 7.5,0 0,7.5 -7.5,0",
        // 2: Upward triangle
        "0,-7.5 6.5,3.75 -6.5,3.75",
        // 3: Pentagon
        "0,-7.5 7.1,-2.3 4.4,6.1 -4.4,6.1 -7.1,-2.3",
        // 4: Five-pointed star
        "0,-7.5 2.1,-2.8 7.1,-2.3 3.3,1.1 4.4,6.1 0,3.5 -4.4,6.1 -3.3,1.1 -7.1,-2.3 -2.1,-2.8",
    ];

    private static readonly (string label, string fillId)[] TerrainLegend =
    [
        ("Street",     "url(#pattern-street)"),
        ("Apartment",  "url(#pattern-apartment)"),
        ("Storefront", "url(#pattern-storefront)"),
        ("Park",       "url(#pattern-park)"),
        ("Industrial", "url(#pattern-industrial)"),
        ("Forest",     "url(#pattern-forest)"),
        ("River",      "url(#pattern-river)"),
    ];

    protected override void OnParametersSet()
    {
        if (World != _lastWorld)
        {
            _lastWorld = World;
            _buildings = ComputeBuildings();
        }

        if (FollowedAgent != null)
        {
            // Zoom to max on first follow, then re-center every update
            if (FollowedAgent != _prevFollowedAgent)
            {
                _cellSize = _zoomLevels[^1];
                _buildings = ComputeBuildings();
            }
            _pendingCenter = true;
        }
        else if (CurrentAgent != null && CurrentAgent != _prevCurrentAgent)
        {
            // No follow mode: zoom to max when a new agent starts their turn
            _cellSize = _zoomLevels[^1];
            _buildings = ComputeBuildings();
            _pendingCenter = true;
        }

        _prevFollowedAgent = FollowedAgent;
        _prevCurrentAgent  = CurrentAgent;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pendingCenter)
        {
            var target = FollowedAgent ?? CurrentAgent;
            if (target != null)
            {
                _pendingCenter = false;
                var (ax, ay) = World.GetAgentPosition(target);
                if (ax >= 0)
                {
                    double px = ax * _cellSize + _cellSize / 2.0;
                    double py = ay * _cellSize + _cellSize / 2.0;
                    try { await JS.InvokeVoidAsync("centerMapOnAgent", _scrollContainer, px, py); }
                    catch { }
                }
            }
        }
    }

    private List<BuildingData> ComputeBuildings()
    {
        var groups = new Dictionary<string, (int minX, int maxX, int minY, int maxY, int floors, TerrainType terrain)>();
        for (int row = 0; row < World.MapHeight; row++)
        {
            for (int col = 0; col < World.MapWidth; col++)
            {
                var cell = World.GetCell(col, row);
                var name = cell.BuildingName;
                if (name is null) continue;
                if (groups.TryGetValue(name, out var b))
                    groups[name] = (Math.Min(b.minX, col), Math.Max(b.maxX, col),
                                    Math.Min(b.minY, row), Math.Max(b.maxY, row), b.floors, b.terrain);
                else
                    groups[name] = (col, col, row, row, cell.Floors, cell.Terrain);
            }
        }
        var result = new List<BuildingData>(groups.Count);
        foreach (var (name, b) in groups)
        {
            double cx  = ((b.minX + b.maxX) / 2.0 + 0.5) * _cellSize;
            double cy  = ((b.minY + b.maxY) / 2.0 + 0.5) * _cellSize;
            double ox  = b.minX * _cellSize;
            double oy  = b.minY * _cellSize;
            double ow  = (b.maxX - b.minX + 1) * _cellSize;
            double oh  = (b.maxY - b.minY + 1) * _cellSize;
            result.Add(new BuildingData(AbbreviateName(name), cx, cy, b.floors, ox, oy, ow, oh, b.terrain));
        }
        return result;
    }

    private static string AbbreviateName(string name)
    {
        var words = name.Split(' ');
        // Skip leading "The" and return the next word
        string first = words[0].Equals("The", StringComparison.OrdinalIgnoreCase) && words.Length > 1
            ? words[1] : words[0];
        // Two-word abbrev for "Elm Street…"
        if (first.Equals("Elm", StringComparison.OrdinalIgnoreCase) && words.Length > 1)
            return "Elm St.";
        return first.Length > 9 ? first[..8] : first;
    }

    private void ZoomOut()
    {
        int idx = Array.IndexOf(_zoomLevels, _cellSize);
        if (idx > 0) { _cellSize = _zoomLevels[idx - 1]; _buildings = ComputeBuildings(); StateHasChanged(); }
    }

    private void ZoomIn()
    {
        int idx = Array.IndexOf(_zoomLevels, _cellSize);
        if (idx < _zoomLevels.Length - 1) { _cellSize = _zoomLevels[idx + 1]; _buildings = ComputeBuildings(); StateHasChanged(); }
    }

    private static string BuildingOutlineColor(TerrainType t) => t switch
    {
        TerrainType.Apartment  => "#7a4a30",
        TerrainType.Storefront => "#2a5a88",
        TerrainType.Industrial => "#7a5a18",
        TerrainType.Park       => "#3a7a42",
        TerrainType.Forest     => "#2a6a32",
        TerrainType.River      => "#1050a0",
        _                      => "#3a3a4a",
    };

    private static string BuildingFillColor(TerrainType t) => t switch
    {
        TerrainType.Apartment  => "#c87848",
        TerrainType.Storefront => "#4888cc",
        TerrainType.Industrial => "#c89828",
        TerrainType.Park       => "#48c068",
        TerrainType.Forest     => "#38a048",
        TerrainType.River      => "#2060e0",
        _                      => "#888888",
    };

    private static string HealthRingColor(float hunger, float thirst)
    {
        float min = Math.Min(hunger, thirst);
        return min <= 20f ? "#ef4444" : min <= 40f ? "#f59e0b" : "#22c55e";
    }

    private static string AnimalGlyph(AnimalType t) => t switch
    {
        AnimalType.Rat        => "🐀",
        AnimalType.Pigeon     => "🐦",
        AnimalType.StreetCat  => "🐱",
        AnimalType.Squirrel   => "🐿",
        AnimalType.Fox        => "🦊",
        AnimalType.DogPack    => "🐕",
        AnimalType.Rottweiler => "🦮",
        AnimalType.PitBull    => "🐶",
        AnimalType.Coyote     => "🐺",
        AnimalType.Deer       => "🦌",
        _                     => "·",
    };

    private static string TerrainFill(TerrainType terrain) => terrain switch
    {
        TerrainType.Street     => "url(#pattern-street)",
        TerrainType.Apartment  => "url(#pattern-apartment)",
        TerrainType.Storefront => "url(#pattern-storefront)",
        TerrainType.Park       => "url(#pattern-park)",
        TerrainType.Industrial => "url(#pattern-industrial)",
        TerrainType.Forest     => "url(#pattern-forest)",
        TerrainType.River      => "url(#pattern-river)",
        _                      => "#0f0f1e"
    };
}
