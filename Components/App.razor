<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Multi-Agent Simulation</title>
    <base href="/" />
    <link rel="stylesheet" href="app.css" />
    <HeadOutlet />
</head>
<body>
    <Routes />
    <script>
        window.scrollToBottom    = (el) => { if (el) el.scrollTop = el.scrollHeight; };
        window.scrollToTop       = (el) => { if (el) el.scrollTop = 0; };
        window.scrollToRight     = (el) => { if (el) el.scrollLeft = el.scrollWidth; };
        window.centerMapOnAgent  = (el, px, py) => {
            if (!el) return;
            el.scrollLeft = px - el.clientWidth  / 2;
            el.scrollTop  = py - el.clientHeight / 2;
        };
    </script>
    <script src="_framework/blazor.server.js"></script>
</body>
</html>
